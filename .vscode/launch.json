{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Streamlit",
            "type": "python",
            "request": "launch",
            "module": "streamlit.cli",
            "args": [
                "run",
                "streamlit_app.py",
                "--server.address",
                "0.0.0.0",
                "--server.port",
                "8502"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Open Streamlit in Chrome",
            "type": "pwa-chrome",
            "request": "launch",
            "url": "http://localhost:8502",
            "webRoot": "${workspaceFolder}"
        },
        {
            "name": "Open Streamlit in Edge",
            "type": "pwa-msedge",
            "request": "launch",
            "url": "http://localhost:8502",
            "webRoot": "${workspaceFolder}"
        },
        {
            "name": "Open Streamlit in Firefox",
            "type": "pwa-firefox",
            "request": "launch",
            "url": "http://localhost:8502",
            "webRoot": "${workspaceFolder}"
        }
    ]
}
